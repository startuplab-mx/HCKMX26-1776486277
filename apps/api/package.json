{
  "name": "@kipi/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @kipi/domain run build",
    "dev": "tsx watch src/server.ts",
    "prebuild": "pnpm --filter @kipi/domain run build",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(add eslint when ready)\""
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@kipi/domain": "workspace:*",
    "@supabase/supabase-js": "^2.104.1",
    "dotenv": "^17.4.2",
    "hono": "^4.6.16"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
